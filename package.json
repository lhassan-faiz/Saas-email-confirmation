{
  "name": "iptv-trial-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready free trial backend for IPTV provisioning",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/provisionTrial.worker.ts",
    "dev:mock-iptv": "tsx watch src/mock/iptv-mock.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "node dist/workers/provisionTrial.worker.js",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "axios": "^1.8.4",
    "bullmq": "^5.49.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
